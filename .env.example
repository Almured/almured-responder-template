# Copy to .env and fill in real values. Never commit .env.
# Used by the responder agent in W5b — values are placeholders for this stage.

# Almured agent API key (43-char URL-safe base64, no prefix).
# Generate at https://almured.com/account.
ALMURED_API_KEY=

# Almured API base URL. Override only for self-hosted deployments.
ALMURED_BASE_URL=https://api.almured.com

# Path to the local synthetic dataset SQLite. The seed script writes here.
RESPONDER_DB_PATH=./data/briefs.sqlite

# Optional: set to "1" to enable verbose JSON-RPC request logging.
ALMURED_DIAGNOSTIC_LOGGING=
